<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-5 mb-0">Meal Kits List</h1>
    <div>
      <a href="/mealkits/add" class="btn btn-success">Add</a>
      <a href="/load-data/mealkits" class="btn btn-primary ms-2">Load Data</a>
    </div>
  </div>

  <% if (mealKits && mealKits.length > 0) { %>
    <div class="row">
      <% mealKits.forEach(mealKit => { %>
        <div class="col-md-6 col-lg-4 mb-4">
          <div class="card h-100 shadow-sm">
            <img
              src="<%= mealKit.imageUrl %>"
              class="card-img-top"
              style="height: 200px; object-fit: cover;"
              alt="<%= mealKit.title %>"
            >
            <div class="card-body">
              <h5 class="card-title"><%= mealKit.title %></h5>
              <p class="text-muted mb-1"><%= mealKit.includes %></p>
              <p class="card-text"><%= mealKit.description %></p>
              <p class="mb-1"><strong>Category:</strong> <%= mealKit.category %></p>
              <p class="mb-1"><strong>Price:</strong> $<%= mealKit.price %></p>
              <p class="mb-1"><strong>Cooking Time:</strong> <%= mealKit.cookingTime %> minutes</p>
              <p class="mb-1"><strong>Servings:</strong> <%= mealKit.servings %></p>
              <p class="mb-1"><strong>Featured:</strong> <%= mealKit.featuredMealKit ? 'Yes' : 'No' %></p>
              <div class="d-flex gap-2">
                <a href="/mealkits/edit/<%= mealKit._id %>" class="btn btn-warning btn-sm">Edit</a>
                <a href="/mealkits/remove/<%= mealKit._id %>" class="btn btn-danger btn-sm">Delete</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center">
      <p class="lead">No meal kits found. <a href="/load-data/mealkits">Load sample data</a></p>
    </div>
  <% } %>
</div>