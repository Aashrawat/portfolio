<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="display-5 text-center mb-4">Edit Meal Kit</h1>

      <form action="/mealkits/edit/<%= values._id %>" method="POST" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Title *</label>
          <input type="text" class="form-control <%= errors.title ? 'is-invalid' : '' %>" id="title" name="title" value="<%= values.title || '' %>">
          <% if (errors.title) { %>
            <div class="invalid-feedback"><%= errors.title %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="includes" class="form-label">Includes *</label>
          <input type="text" class="form-control <%= errors.includes ? 'is-invalid' : '' %>" id="includes" name="includes" value="<%= values.includes || '' %>">
          <% if (errors.includes) { %>
            <div class="invalid-feedback"><%= errors.includes %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description *</label>
          <textarea class="form-control <%= errors.description ? 'is-invalid' : '' %>" id="description" name="description" rows="3"><%= values.description || '' %></textarea>
          <% if (errors.description) { %>
            <div class="invalid-feedback"><%= errors.description %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="category" class="form-label">Category *</label>
          <input type="text" class="form-control <%= errors.category ? 'is-invalid' : '' %>" id="category" name="category" value="<%= values.category || '' %>">
          <% if (errors.category) { %>
            <div class="invalid-feedback"><%= errors.category %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="price" class="form-label">Price *</label>
          <input type="number" step="0.01" min="0.01" class="form-control <%= errors.price ? 'is-invalid' : '' %>" id="price" name="price" value="<%= values.price || '' %>">
          <% if (errors.price) { %>
            <div class="invalid-feedback"><%= errors.price %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="cookingTime" class="form-label">Cooking Time (minutes) *</label>
          <input type="number" min="1" class="form-control <%= errors.cookingTime ? 'is-invalid' : '' %>" id="cookingTime" name="cookingTime" value="<%= values.cookingTime || '' %>">
          <% if (errors.cookingTime) { %>
            <div class="invalid-feedback"><%= errors.cookingTime %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="servings" class="form-label">Servings *</label>
          <input type="number" min="1" class="form-control <%= errors.servings ? 'is-invalid' : '' %>" id="servings" name="servings" value="<%= values.servings || '' %>">
          <% if (errors.servings) { %>
            <div class="invalid-feedback"><%= errors.servings %></div>
          <% } %>
        </div>

        <div class="mb-3">
          <label for="imageUrl" class="form-label">Image (leave empty to keep current image)</label>
          <input type="file" class="form-control <%= errors.imageUrl ? 'is-invalid' : '' %>" id="imageUrl" name="imageUrl" accept=".jpg,.jpeg,.png,.gif">
          <% if (errors.imageUrl) { %>
            <div class="invalid-feedback"><%= errors.imageUrl %></div>
          <% } %>
        </div>

        <div class="mb-3 form-check">
          <input type="checkbox" class="form-check-input" id="featuredMealKit" name="featuredMealKit" <%= values.featuredMealKit ? 'checked' : '' %>>
          <label class="form-check-label" for="featuredMealKit">Featured Meal Kit</label>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-success">Update Meal Kit</button>
          <a href="/mealkits/list" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>