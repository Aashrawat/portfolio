<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="display-5 text-center mb-4">Remove Meal Kit</h1>

      <div class="card">
        <img
          src="<%= mealKit.imageUrl %>"
          class="card-img-top"
          style="height: 250px; object-fit: cover;"
          alt="<%= mealKit.title %>"
        >
        <div class="card-body">
          <h5 class="card-title"><%= mealKit.title %></h5>
          <p class="text-muted mb-1"><%= mealKit.includes %></p>
          <p class="card-text"><%= mealKit.description %></p>
          <p class="mb-1"><strong>Category:</strong> <%= mealKit.category %></p>
          <p class="mb-1"><strong>Price:</strong> $<%= mealKit.price %></p>
          <p class="mb-1"><strong>Cooking Time:</strong> <%= mealKit.cookingTime %> minutes</p>
          <p class="mb-1"><strong>Servings:</strong> <%= mealKit.servings %></p>
          <p class="mb-1"><strong>Featured:</strong> <%= mealKit.featuredMealKit ? 'Yes' : 'No' %></p>
        </div>
      </div>

      <div class="alert alert-warning mt-4">
        <h5>Are you sure you want to delete this meal kit?</h5>
        <p class="mb-0">This action cannot be undone. The image file will also be deleted.</p>
      </div>

      <div class="d-flex gap-2 mt-4">
        <form action="/mealkits/remove/<%= mealKit._id %>" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger">Yes, Delete</button>
        </form>
        <a href="/mealkits/list" class="btn btn-secondary">Cancel</a>
      </div>
    </div>
  </div>
</div>